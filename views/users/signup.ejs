<% layout("/layouts/boilerplate") %>

<div class="row mt-3">
  <div class="col-6 offset-3">
    <h3 class="mb-4">Sign Up on Wanderlust</h3>

    <form action="/signup" method="POST" class="needs-validation" novalidate>

      <!-- Username -->
      <div class="mb-3">
        <label for="username" class="form-label">Username</label>
        <input 
          type="text" 
          name="username" 
          id="username" 
          class="form-control" 
          required
        />
        <div class="valid-feedback">Looks good!</div>
      </div>

      <!-- Email -->
      <div class="mb-3">
        <label for="email" class="form-label">Email</label>
        <input 
          type="email" 
          name="email" 
          id="email" 
          class="form-control" 
          required
        >
        <div class="valid-feedback">Looks good!</div>
      </div>

      <!-- Password -->
      <div class="mb-3">
        <label for="password" class="form-label">Password</label>
        <input 
          type="password" 
          name="password" 
          id="password" 
          class="form-control" 
          required
        >
        <div class="valid-feedback">Looks good!</div>
      </div>

      <!-- Submit Button -->
      <button type="submit" class="btn btn-success">
        Sign Up
      </button>

    </form>
  </div>
</div>